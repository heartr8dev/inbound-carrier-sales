# HappyRobot platform API key (provisioning + agent runtime).
HAPPYROBOT_API_KEY=

# FMCSA QC Mobile webKey for carrier authority/safety lookups.
FMCSA_WEBKEY=

# Static bearer for X-API-Key header on every /api/v1/* request.
API_KEY=devkey-please-change

# SQLAlchemy async URL — asyncpg driver against the compose db service.
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/inbound

# Comma-separated list of allowed dashboard origins for CORS.
DASHBOARD_ORIGIN=http://localhost:5173

# Maximum discount from loadboard_rate the negotiation engine can give.
MAX_DISCOUNT_PCT=0.10

# Used by Workstream J video pipeline (GPT Image 2 stills).
OPENAI_API_KEY=

# Used by Workstream J video pipeline (Seedance 2 via WaveSpeed).
WAVESPEED_API_KEY=

# Used by Workstream J video pipeline (narration TTS).
ELEVENLABS_API_KEY=
